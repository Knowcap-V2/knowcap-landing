
# SMTP Configuration for Email Notifications
# Used for sending beta application notifications to hsa@knowcap.ai

# SMTP Server Host (e.g., smtp.gmail.com for Gmail)
SMTP_HOST=smtp.gmail.com

# SMTP Server Port (587 for TLS, 465 for SSL)
SMTP_PORT=587

# Use SSL/TLS (true for port 465, false for port 587)
SMTP_SECURE=false

# SMTP Username (usually your email address)
SMTP_USER=your-email@gmail.com

# SMTP Password or App Password
# For Gmail: Use an App Password (https://myaccount.google.com/apppasswords)
# Do NOT use your regular Gmail password
SMTP_PASS=your-app-password

# From Email Address (optional, defaults to SMTP_USER)
SMTP_FROM=your-email@gmail.com
